{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": false,
    "lib": ["DOM", "ES2019"],
    "baseUrl": ".."
  },
  "include": [
    "./**/*.ts",
    "../src/widgets/**/*.d.ts"
  ]
}

